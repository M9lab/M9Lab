# ================= REPLICATE (obbligatori) =================
replicateToken=r8_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Nome modello (non id versione), es. openai/gpt-image-1.5
REPLICATE_MODEL=openai/gpt-image-1.5

# Colori logo nel render (esadecimale senza #)
LOGO_TEXT_COLOR=F5EA25
LOGO_BG_COLOR=5BA4D1
# Chiamate Replicate rimanenti (persistite in file; qui valore iniziale o dopo ricalcolo)
REPLICATE_CALLS_LEFT=150
# Opzionali Replicate
# REPLICATE_LEGO_PROMPT=... (se non impostato usa default con colori logo sopra)
# REPLICATE_QUALITY=medium
# REPLICATE_OUTPUT_FORMAT=webp

# ================= DIMENSIONI (3:2, width 1024) =================
PHOTO_W=1024
PHOTO_H=683
PREVIEW_LIVE_W=1024
PREVIEW_LIVE_H=683
PREVIEW_RESULT_W=800
PREVIEW_RESULT_H=533
WEBCAM_CAPTURE_W=1024
WEBCAM_CAPTURE_H=683
COUNTDOWN_SECONDS=3

# ================= CARTELLE =================
INPUT_DIR=input_photos
OUTPUT_DIR=output_photos

# ================= EMAIL =================
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx
EMAIL_SUBJECT=La tua foto LEGO

# ================= TESTI INTERFACCIA =================
BTN_SHOOT_TEXT=SCATTA UNA FOTO
BTN_CANCEL_TEXT=ANNULLA
BTN_SEND_TEXT=INVIA FOTO
BTN_EXIT_TEXT=ESCI
STATUS_READY=Premi SCATTA UNA FOTO (o premi SPAZIO o INVIO)
STATUS_ENTER_EMAIL=Inserisci email e premi INVIO o TAB
STATUS_LEGO_PROCESSING=Elaborazione Foto in corso...
STATUS_LEGO_ERROR=Errore elaborazione: {error}
STATUS_CAPTURE_PREVIEW=Anteprima: Annulla per tornare, Legolizza per procedere
BTN_LEGOLIZE_TEXT=LEGOLIZZA
EMAIL_PLACEHOLDER=Inserisci la tua email
EMAIL_PRIVACY_NOTICE=Useremo la tua email solo per questa operazione. Niente archiviazione, niente spam.
EVENT_TEXT="Maker Faire Trieste 2026"
FONT_SIZE_EVENT_TEXT=60

# ================= RASPBERRY PI / RISORSE LIMITATE =================
# Su Raspberry 3 impostare LEGOLIZE_LOW_RESOURCE=1 (o usare .env.raspberry)
# LEGOLIZE_LOW_RESOURCE=1   riduce FPS preview, usa interpolazione veloce, spinner più lento
# PREVIEW_INTERVAL_MS=150   intervallo preview in ms (50=20 FPS, 150=~7 FPS)
# SPINNER_INTERVAL_MS=100   intervallo rotellina caricamento (ms)
# SKIP_LOGO_PATTERN=1       salta sfondo a tiled logo (risparmia RAM/CPU)

# ================= UI (logo e puntamento da cartella fotomachine) =================
UI_BG_COLOR=#5DADE2
UI_LOGO_PATH=logo.png
# PUNTAMENTO_FILE=puntamento.png  (in fotomachine, overlay in preview)
